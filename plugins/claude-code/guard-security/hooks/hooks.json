{
  "description": "Focused Guard hook runtime for Claude Code",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session_start.sh"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/cwd_changed_guard.sh"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "package.json|pnpm-lock.yaml|pnpm-workspace.yaml|policy.yaml|CODEOWNERS",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/file_changed_guard.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(pnpm add*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(pnpm up*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(pnpm install*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(pnpm remove*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm install*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm update*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm uninstall*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(corepack use*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(claude plugins marketplace add*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(claude plugins install*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(claude mcp add*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(codex plugins marketplace add*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(codex plugins install*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(codex mcp add*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(codex skills install*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(npx skills add*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(gemini extensions install*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(curl*bash*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(curl*sh*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(curl*zsh*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(wget*bash*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(wget*sh*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(wget*zsh*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(bash*curl*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(sh*curl*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(zsh*curl*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(bash*wget*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(sh*wget*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(zsh*wget*)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre_bash_guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_write_guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(pnpm add*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(pnpm up*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(pnpm install*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(pnpm remove*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm install*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm update*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(npm uninstall*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(corepack use*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(claude plugins marketplace add*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(claude plugins install*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(claude mcp add*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(codex plugins marketplace add*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(codex plugins install*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(codex mcp add*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(codex skills install*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(npx skills add*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(gemini extensions install*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(curl*bash*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(curl*sh*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(curl*zsh*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(wget*bash*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(wget*sh*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(wget*zsh*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(bash*curl*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(sh*curl*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(zsh*curl*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(bash*wget*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(sh*wget*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          },
          {
            "type": "command",
            "if": "Bash(zsh*wget*)",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_bash_guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/stop_summary.sh"
          }
        ]
      }
    ]
  }
}
